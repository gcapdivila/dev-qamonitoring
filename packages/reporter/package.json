{
  "name": "@quality-observability/playwright-reporter",
  "version": "0.1.0",
  "description": "Run-level observability reporter for Playwright test execution. Emits aggregated metrics to InfluxDB for Grafana dashboards.",
  "repository": {
    "type": "git",
    "url": "https://github.com/gcapdivila/dev-qamonitoring",
    "directory": "package/reporter"
  },
  "homepage": "https://github.com/gcapdivila/dev-qamonitoring#readme",
  "bugs": {
    "url": "https://github.com/gcapdivila/dev-qamonitoring/issues"
  },
  "keywords": [
    "playwright",
    "reporter",
    "observability",
    "metrics",
    "influxdb",
    "grafana",
    "qa",
    "testing"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "dashboards",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "license": "MIT",
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
